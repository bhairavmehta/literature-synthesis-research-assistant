# Copy to .env and edit. ALL are optional: with no .env the system runs fully
# offline in deterministic stub mode.

# Provider: stub (default, offline) | openai | anthropic
LSRA_PROVIDER=stub

# Live retrieval from arXiv instead of the local corpus (1 to enable)
LSRA_ONLINE_RETRIEVAL=0

# --- API keys (only if LSRA_PROVIDER is openai/anthropic) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LSRA_OPENAI_MODEL=gpt-4o-mini
# LSRA_ANTHROPIC_MODEL=claude-sonnet-4-6
# LSRA_EMBED_MODEL=text-embedding-3-small

# --- tunables (defaults match the capstone report) ---
# LSRA_GROUNDING_THRESHOLD=0.28
# LSRA_CONFORMAL_ALPHA=0.10
# LSRA_TOP_K_RECALL=12
# LSRA_TOP_K_RERANK=5
